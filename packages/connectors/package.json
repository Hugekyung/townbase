{
  "name": "@townbase/connectors",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "notion:sync": "ts-node --project tsconfig.json src/sync.ts",
    "notion:sync:fixture": "ts-node --project tsconfig.json src/sync.ts --fixture-path packages/connectors/fixtures/notion-sync.fixture.json",
    "local-repo:sync": "ts-node --project tsconfig.json src/local-repo/entrypoint.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "@townbase/database": "workspace:*",
    "@townbase/rag-core": "workspace:*"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2"
  }
}
