PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://townbase:townbase@localhost:5432/townbase?schema=public
POSTGRES_USER=townbase
POSTGRES_PASSWORD=townbase
POSTGRES_DB=townbase

# MCP / answer generation
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# Notion ingestion
NOTION_API_KEY=
NOTION_ROOT_PAGE_ID=
# Fixture replay is explicit via `pnpm --filter @townbase/connectors notion:sync:fixture`.

# Local repository ingestion
REPO_ROOT_PATH=./repos
LOCAL_REPO_NAMES=workspace-knowledge-agent
